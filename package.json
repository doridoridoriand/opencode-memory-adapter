{
  "name": "opencode-memory-plugin",
  "description": "OpenCode plugin that provides persistent memory functionality via multiple provider backends",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "exports": "./dist/index.js",
  "files": ["dist", "scripts", "README.md", "LICENSE"],
  "bin": {
    "opencode-memory-plugin": "./scripts/init-config.js"
  },
  "scripts": {
    "build": "tsc",
    "hooks:install": "node scripts/install-hooks.js",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "init": "node scripts/init-config.js init",
    "scan:sensitive": "node scripts/sensitive-scan.js --tracked",
    "scan:sensitive:staged": "node scripts/sensitive-scan.js --staged",
    "audit:public": "node scripts/sensitive-scan.js --public-audit",
    "test": "npm run test:suite",
    "test:suite": "vitest run --config vitest.config.ts",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0",
    "mem0ai": ">=3.0.0",
    "@honcho-ai/sdk": ">=2.0.0",
    "@yfedberts/huscarl": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "mem0ai": { "optional": true },
    "@honcho-ai/sdk": { "optional": true },
    "@yfedberts/huscarl": { "optional": true }
  },
  "dependencies": {
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  }
}
